# Local (non-Docker) backend env. Copy to backend/.env
PORT=8000
DATABASE_URL=postgresql://rpm_user:rpm_secure_2026@localhost:5432/rpm_crm

GMAIL_EMAIL=support@rapidmoney.in
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_POLL_ENABLED=true
EMAIL_POLL_INTERVAL=60

# Auto-acknowledge low-priority (P3) tickets on ingest (spam excluded).
# OFF by default — this emails real customers and the first poll processes the
# entire UNSEEN backlog at once.
AUTO_REPLY_ENABLED=false

SUPERVISOR_EMAIL=amit.agashe@rapidmoney.in
PORTAL_URL=http://localhost:3000
SLA_P1_HOURS=4
SLA_P2_HOURS=24
SLA_P3_HOURS=48
SLA_CHECK_INTERVAL=300
SLA_ALERTS_ENABLED=false

ANTHROPIC_API_KEY=

# UAT sink — redirect ALL outbound email here instead of the customer (blank = off)
UAT_REDIRECT_EMAIL=

# ── Auth / RBAC ──
# Secret for signing JWTs — MUST be a long random string in production.
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_IN=7d
# Frontend origin used in emailed create-password / reset-password links.
FRONTEND_URL=http://localhost:3000
# Bootstrap admin — seeded only when the users table is empty.
BOOTSTRAP_ADMIN_EMAIL=admin@rapidmoney.in
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!123
BOOTSTRAP_ADMIN_NAME=Administrator
